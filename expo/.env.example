# Supabase configuration — copy this file to `.env` and fill in your values.
# IMPORTANT: use the PUBLISHABLE (anon) key only. Never put the secret/service-role key in the app.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
